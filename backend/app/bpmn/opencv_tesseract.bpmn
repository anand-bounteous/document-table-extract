      <bpmndi:BPMNEdge id="edge_flow_table_crop_table_obfuscate" bpmnElement="flow_table_crop_table_obfuscate"><di:waypoint x="1162" y="108"/><di:waypoint x="1206" y="108"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_table_obfuscate_annotate_render" bpmnElement="flow_table_obfuscate_annotate_render"><di:waypoint x="1336" y="108"/><di:waypoint x="1380" y="108"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_annotate_render_End" bpmnElement="flow_annotate_render_End"><di:waypoint x="1510" y="108"/><di:waypoint x="1554" y="108"/></bpmndi:BPMNEdge>
