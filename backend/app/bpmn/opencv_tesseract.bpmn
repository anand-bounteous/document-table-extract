      <bpmndi:BPMNShape id="shape_layout_ruled_table" bpmnElement="layout_ruled_table"><dc:Bounds x="510" y="82" width="130" height="52"/><bpmndi:BPMNLabel/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_pii_presidio" bpmnElement="pii_presidio"><dc:Bounds x="684" y="82" width="130" height="52"/><bpmndi:BPMNLabel/></bpmndi:BPMNShape>
