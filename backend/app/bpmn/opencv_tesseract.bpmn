  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  id="Definitions_opencv_tesseract"
  targetNamespace="http://sof-table-extract"
  exporter="sof-table-extract" exporterVersion="0.2">

  <bpmn:process id="opencv_tesseract" name="OpenCV → Tesseract → ruled tables" isExecutable="true">
    <bpmn:startEvent id="StartEvent_opencv_tesseract" name="Start"/>
    <bpmn:sequenceFlow id="flow_Start_preprocess_opencv" sourceRef="StartEvent_opencv_tesseract" targetRef="preprocess_opencv"/>
    <bpmn:sequenceFlow id="flow_preprocess_opencv_ocr_tesseract" sourceRef="preprocess_opencv" targetRef="ocr_tesseract"/>
    <bpmn:sequenceFlow id="flow_ocr_tesseract_layout_ruled_table" sourceRef="ocr_tesseract" targetRef="layout_ruled_table"/>
    <bpmn:sequenceFlow id="flow_layout_ruled_table_pii_presidio" sourceRef="layout_ruled_table" targetRef="pii_presidio"/>
    <bpmn:sequenceFlow id="flow_pii_presidio_layout_custom_table" sourceRef="pii_presidio" targetRef="layout_custom_table"/>
    <bpmn:sequenceFlow id="flow_layout_custom_table_table_crop" sourceRef="layout_custom_table" targetRef="table_crop"/>
    <bpmn:sequenceFlow id="flow_table_crop_table_obfuscate" sourceRef="table_crop" targetRef="table_obfuscate"/>
    <bpmn:sequenceFlow id="flow_table_obfuscate_annotate_render" sourceRef="table_obfuscate" targetRef="annotate_render"/>
    <bpmn:sequenceFlow id="flow_annotate_render_End" sourceRef="annotate_render" targetRef="EndEvent_opencv_tesseract"/>
    <bpmn:task id="preprocess_opencv" name="Preprocess Opencv"><bpmn:extensionElements><camunda:field name="stage_name"><camunda:string>preprocess_opencv</camunda:string></camunda:field></bpmn:extensionElements></bpmn:task>
    <bpmn:task id="ocr_tesseract" name="Ocr Tesseract"><bpmn:extensionElements><camunda:field name="stage_name"><camunda:string>ocr_tesseract</camunda:string></camunda:field></bpmn:extensionElements></bpmn:task>
    <bpmn:task id="layout_ruled_table" name="Layout Ruled Table"><bpmn:extensionElements><camunda:field name="stage_name"><camunda:string>layout_ruled_table</camunda:string></camunda:field></bpmn:extensionElements></bpmn:task>
    <bpmn:task id="pii_presidio" name="Pii Presidio"><bpmn:extensionElements><camunda:field name="stage_name"><camunda:string>pii_presidio</camunda:string></camunda:field></bpmn:extensionElements></bpmn:task>
    <bpmn:task id="layout_custom_table" name="Layout Custom Table"><bpmn:extensionElements><camunda:field name="stage_name"><camunda:string>layout_custom_table</camunda:string></camunda:field></bpmn:extensionElements></bpmn:task>
    <bpmn:task id="table_crop" name="Table Crop"><bpmn:extensionElements><camunda:field name="stage_name"><camunda:string>table_crop</camunda:string></camunda:field></bpmn:extensionElements></bpmn:task>
    <bpmn:task id="table_obfuscate" name="Table Obfuscate"><bpmn:extensionElements><camunda:field name="stage_name"><camunda:string>table_obfuscate</camunda:string></camunda:field></bpmn:extensionElements></bpmn:task>
    <bpmn:task id="annotate_render" name="Annotate Render"><bpmn:extensionElements><camunda:field name="stage_name"><camunda:string>annotate_render</camunda:string></camunda:field></bpmn:extensionElements></bpmn:task>
    <bpmn:endEvent id="EndEvent_opencv_tesseract" name="End"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="opencv_tesseract">
      <bpmndi:BPMNShape id="shape_StartEvent_opencv_tesseract" bpmnElement="StartEvent_opencv_tesseract"><dc:Bounds x="82" y="90" width="36" height="36"/><bpmndi:BPMNLabel/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_preprocess_opencv" bpmnElement="preprocess_opencv"><dc:Bounds x="162" y="82" width="130" height="52"/><bpmndi:BPMNLabel/></bpmndi:BPMNShape>
