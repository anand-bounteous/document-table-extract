      <bpmndi:BPMNShape id="shape_table_obfuscate" bpmnElement="table_obfuscate"><dc:Bounds x="1206" y="82" width="130" height="52"/><bpmndi:BPMNLabel/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_annotate_render" bpmnElement="annotate_render"><dc:Bounds x="1380" y="82" width="130" height="52"/><bpmndi:BPMNLabel/></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_EndEvent_opencv_tesseract" bpmnElement="EndEvent_opencv_tesseract"><dc:Bounds x="1554" y="90" width="36" height="36"/><bpmndi:BPMNLabel/></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="edge_flow_Start_preprocess_opencv" bpmnElement="flow_Start_preprocess_opencv"><di:waypoint x="118" y="108"/><di:waypoint x="162" y="108"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_preprocess_opencv_ocr_tesseract" bpmnElement="flow_preprocess_opencv_ocr_tesseract"><di:waypoint x="292" y="108"/><di:waypoint x="336" y="108"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_ocr_tesseract_layout_ruled_table" bpmnElement="flow_ocr_tesseract_layout_ruled_table"><di:waypoint x="466" y="108"/><di:waypoint x="510" y="108"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_layout_ruled_table_pii_presidio" bpmnElement="flow_layout_ruled_table_pii_presidio"><di:waypoint x="640" y="108"/><di:waypoint x="684" y="108"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_pii_presidio_layout_custom_table" bpmnElement="flow_pii_presidio_layout_custom_table"><di:waypoint x="814" y="108"/><di:waypoint x="858" y="108"/></bpmndi:BPMNEdge>
