    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="docling_doctr">
      <bpmndi:BPMNShape id="shape_StartEvent_docling_doctr" bpmnElement="StartEvent_docling_doctr"><dc:Bounds x="82" y="90" width="36" height="36"/><bpmndi:BPMNLabel/></bpmndi:BPMNShape>
