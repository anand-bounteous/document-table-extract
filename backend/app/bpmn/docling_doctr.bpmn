  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  id="Definitions_docling_doctr"
  targetNamespace="http://sof-table-extract"
  exporter="sof-table-extract" exporterVersion="0.2">

  <bpmn:process id="docling_doctr" name="docling · DocTR" isExecutable="true">
    <bpmn:startEvent id="StartEvent_docling_doctr" name="Start"/>
    <bpmn:sequenceFlow id="flow_Start_vision_docling" sourceRef="StartEvent_docling_doctr" targetRef="vision_docling"/>
    <bpmn:sequenceFlow id="flow_vision_docling_pii_presidio" sourceRef="vision_docling" targetRef="pii_presidio"/>
    <bpmn:sequenceFlow id="flow_pii_presidio_layout_doc_format" sourceRef="pii_presidio" targetRef="layout_doc_format"/>
