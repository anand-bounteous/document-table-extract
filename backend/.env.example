# =============================================================================
# sof-table-extract — backend environment template
# =============================================================================
# Copy to `.env` (same directory) and edit values. Pydantic Settings loads
# everything via case-insensitive name lookup against the fields in
# `app/config.py::Settings`. Every variable below corresponds to one field;
# omitted variables fall back to the default shown.
#
# Boolean values accept: true / false / 1 / 0 / yes / no  (case-insensitive).
# List values are comma-separated strings (no JSON, no quoting).
# =============================================================================


# -----------------------------------------------------------------------------
# LLM / vision providers (optional — each enables one vision_* solution)
# -----------------------------------------------------------------------------
# Anthropic — enables the `claude_vision` solution.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8192

# OpenAI — enables the `openai_vision` solution.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini — enables the `gemini_vision` solution.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash


# -----------------------------------------------------------------------------
# Server / I/O
# -----------------------------------------------------------------------------
# Comma-separated list. The Next.js frontend defaults to http://localhost:3000.
CORS_ORIGINS=http://localhost:3000

# Where the original uploaded PDFs live (path is resolved absolute).
DATA_DIR=../data

# Where per-run artifact trees are written.
RUNS_DIR=./storage/runs

# DPI for rasterizing every PDF page. `vision_dpi` is used only by Claude /
# OpenAI / Gemini vision solutions to keep image payloads under the API
# token limits.
DEFAULT_DPI=300
VISION_DPI=200


# -----------------------------------------------------------------------------
# Scheduler / concurrency
# -----------------------------------------------------------------------------
# Solutions run in parallel up to this cap. 0 = auto-tune from free RAM:
#   workers = clamp(free_ram_gb / RAM_PER_SOLUTION_GB, 1, min(n_solutions, 16)).
MAX_CONCURRENT_SOLUTIONS=0
RAM_PER_SOLUTION_GB=3.0


# -----------------------------------------------------------------------------
# PII — encryption key shared by both PII tracks
# -----------------------------------------------------------------------------
# Fernet key (urlsafe base64, 32 bytes). Used to encrypt the
# original-value-to-mock mapping for both the legacy PresidioPII stage and
# the pii_v2 redactor. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If empty, mappings fall back to a per-process key and a warning is logged.
PII_MASK_KEY=


# -----------------------------------------------------------------------------
# pii_v2 — UK banking PII benchmark track
# -----------------------------------------------------------------------------
# Master switch for the pii_v2 dashboard + detector cards.
PII_V2_ENABLED=true

# Run OpenCV QR + pyzbar barcode detection on every pii_run page.
PII_V2_VISUAL_ENABLED=true

# Generate redacted text/image + Fernet-encrypted mapping per cell.
PII_V2_REDACTION_ENABLED=true

# Optional TTF for the image-redactor mock-text draws. Empty = use the
# bundled fallback discovered at runtime.
PII_V2_REDACTION_FONT_PATH=

# Max bbox overlays rendered on the dashboard per page (UI throttle).
PII_V2_MAX_OVERLAYS=50

# Confidence floor for user-defined custom regex / dict matches.
PII_V2_USER_CUSTOM_SCORE=0.85

# Default jurisdictions applied when the UI request omits them.
PII_V2_DEFAULT_JURISDICTIONS=GLOBAL_COMMON,UK

# Default detectors applied when the UI request omits them.
PII_V2_DEFAULT_DETECTORS=presidio_regex,presidio_spacy,gliner,piiranha,hybrid

# Default OCR producers the dashboard picks up when no `ocr_producers`
# is supplied in the create request. Edit if you want a smaller / larger
# producer set for the PII flow.
PII_V2_TEXT_PRODUCERS=native_pymupdf,native_pdfplumber,paddleocr_baseline,ocr_tesseract_baseline,easyocr_baseline,doctr_baseline,trocr_printed,trocr_handwritten,docling,docling_tesseract,docling_rapidocr,docling_doctr,docling_trocr_handwritten

# Where pii_run artifact trees are written.
PII_V2_RUNS_DIR=./storage/pii_runs


# -----------------------------------------------------------------------------
# Native-PDF enrichment (PyMuPDF / pdfplumber cards)
# -----------------------------------------------------------------------------
# Stamp font name / size / color / bold / italic onto every text region's
# `attributes` (PyMuPDF stage). Disable to benchmark the bare extractor.
NATIVE_PYMUPDF_EMIT_FONT_DETAILS=true

# Walk `page.get_drawings()` to detect each text region's background color
# and underline (PyMuPDF stage). Adds `bg_color` and `underline` attributes.
NATIVE_PYMUPDF_EMIT_DRAWINGS=true

# Emit per-page template artifacts (PyMuPDF stage):
#   pymupdf_native/template/template-NNN.pdf  — vector PDF, text glyphs removed
#   pymupdf_native/template/template-NNN.png  — raster of the same
NATIVE_PYMUPDF_EMIT_TEMPLATE=true

# Template content control. By default both are False — the template
# preserves images and vector line-art and only the text glyphs are erased.
# Flip to True for a "structure only" template (useful when benchmarking
# pure layout detectors that should not see visual content).
NATIVE_PYMUPDF_TEMPLATE_REMOVE_IMAGES=false
NATIVE_PYMUPDF_TEMPLATE_REMOVE_GRAPHICS=false

# Run OpenCV QR + pyzbar barcode detection on the page raster from both the
# PyMuPDF and pdfplumber native stages; emits each code as a `RegionType.IMAGE`
# with `attributes.object_type = "visual_code"`.
NATIVE_PDF_EMIT_VISUAL_CODES=true
